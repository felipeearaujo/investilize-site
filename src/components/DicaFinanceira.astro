---
// src/components/DicaFinanceira.astro
---

<div class="dica-container">
    <p class="dica-label">Dica de Gestão Financeira:</p>
    <p class="dica-description">
        Antes de investir, simule o impacto das taxas e impostos no seu lucro final.
    </p>
    <div class="dica-actions">
        <a href="/ferramentas/calculadora-ir-mensal/" class="dica-link">Simular IR 2026 →</a>
        <span class="dica-divider">|</span>
        <a href="/ferramentas/poder- de-compra/" class="dica-link">Ver Poder de Compra →</a>
    </div>
</div>

<style>
    .dica-container {
        /* Fundo em azul bem claro e profissional */
        background-color: #f0f7ff; 
        border-radius: 12px;
        padding: 24px;
        text-align: center;
        margin: 2.5rem 0;
        /* Borda em tom azulado para harmonizar */
        border: 1px solid #bae6fd; 
        box-shadow: 0 4px 6px -1px rgba(0, 61, 107, 0.05);
    }

    .dica-label {
        margin: 0 0 8px 0;
        font-weight: 700;
        /* Azul Marinho para autoridade */
        color: #003d6b; 
        font-size: 1.1rem;
    }

    .dica-description {
        margin: 0 0 16px 0;
        font-size: 0.95rem;
        /* Cinza azulado para leitura leve */
        color: #475569; 
        line-height: 1.5;
    }

    .dica-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
        align-items: center;
    }

    .dica-link {
        /* Azul Royal para o link principal */
        color: #0167c2; 
        text-decoration: none;
        font-weight: 700;
        font-size: 0.9rem;
        transition: all 0.2s ease;
        border-bottom: 2px solid transparent;
    }

    .dica-link:hover {
        /* Muda para o Verde Médio no hover (Gatilho de Sucesso) */
        color: #4bac40; 
        border-bottom-color: #4bac40;
    }

    .dica-divider {
        /* Divisor acompanhando o tom da borda */
        color: #bae6fd; 
        user-select: none;
    }

    /* Ajuste para dispositivos móveis */
    @media (max-width: 480px) {
        .dica-divider { display: none; }
        .dica-actions { flex-direction: column; gap: 10px; }
    }
</style>