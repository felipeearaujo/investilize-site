---
// src/components/AltasEBaixasCripto.astro
---

<div class="painel-cripto">
    <div class="cabecalho-painel">
        <h2>? Radar Cripto: Maiores Movimentaçőes</h2>
        <span id="status-atualizacao" class="status-badge">? Atualizando...</span>
    </div>

    <div class="grid-colunas">
        <div class="coluna altas">
            <h3 class="titulo-coluna text-green">? Maiores Altas (24h)</h3>
            <ul id="lista-cripto-altas" class="lista-ativos">
                <li class="carregando">Buscando dados no mercado...</li>
            </ul>
        </div>

        <div class="coluna baixas">
            <h3 class="titulo-coluna text-red">? Maiores Quedas (24h)</h3>
            <ul id="lista-cripto-quedas" class="lista-ativos">
                <li class="carregando">Buscando dados no mercado...</li>
            </ul>
        </div>
    </div>
</div>

<script>
    async function atualizarRadarCripto() {
        const statusBadge = document.getElementById('status-atualizacao');
        const listaAltas = document.getElementById('lista-cripto-altas');
        const listaQuedas = document.getElementById('lista-cripto-quedas');

        try {
            statusBadge.textContent = "? Atualizando...";
            statusBadge.style.color = "#eab308"; // Amarelo

            // Busca as top 100 moedas em BRL.
            const response = await fetch('https://api.coingecko.com/api/v3/coins/markets?vs_currency=brl&order=market_cap_desc&per_page=100&page=1&sparkline=false');
            
            if (!response.ok) throw new Error("Erro na API da CoinGecko");
            
            const moedas = await response.json();

            // Filtra moedas que năo tem variaçăo registrada e ordena pela variaçăo de 24h
            const moedasValidas = moedas.filter(m => m.price_change_percentage_24h !== null);
            const moedasOrdenadas = moedasValidas.sort((a, b) => b.price_change_percentage_24h - a.price_change_percentage_24h);

            // Extrai o Top 5 e o Bottom 5
            const top5Altas = moedasOrdenadas.slice(0, 5);
            const top5Quedas = moedasOrdenadas.slice(-5).reverse();

            // Funçăo para montar o HTML de cada linha (AGORA SEM IMAGENS)
            const criarLinhaMoeda = (moeda) => {
                const isPositivo = moeda.price_change_percentage_24h > 0;
                const corClasse = isPositivo ? 'text-green' : 'text-red';
                const sinal = isPositivo ? '+' : '';
                
                // Formata o preço (se for muito barato, mostra mais casas decimais)
                const precoFormatado = moeda.current_price < 1 
                    ? moeda.current_price.toFixed(4) 
                    : moeda.current_price.toLocaleString('pt-BR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                return `
                    <li class="item-moeda">
                        <div class="moeda-info">
                            <span class="moeda-sigla">${moeda.symbol.toUpperCase()}</span>
                        </div>
                        <span class="moeda-preco">R$ ${precoFormatado}</span>
                        <span class="moeda-variacao ${corClasse}">${sinal}${moeda.price_change_percentage_24h.toFixed(2)}%</span>
                    </li>
                `;
            };

            // Injeta na tela
            listaAltas.innerHTML = top5Altas.map(criarLinhaMoeda).join('');
            listaQuedas.innerHTML = top5Quedas.map(criarLinhaMoeda).join('');

            // Atualiza o status com a hora exata
            const horaAtual = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
            statusBadge.textContent = `? Atualizado ŕs ${horaAtual}`;
            statusBadge.style.color = "#22c55e"; // Verde

        } catch (error) {
            console.error("Falha ao atualizar radar cripto:", error);
            statusBadge.textContent = "? Erro de conexăo";
            statusBadge.style.color = "#ef4444"; // Vermelho
        }
    }

    // Executa imediatamente ao carregar a página
    atualizarRadarCripto();

    // Atualiza os dados a cada 60 segundos
    setInterval(atualizarRadarCripto, 60000);
</script>

<style>
    /* Estilizaçăo limpa e moderna para combinar com o Investilize */
    .painel-cripto {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        margin: 2rem 0;
        font-family: system-ui, -apple-system, sans-serif;
    }

    .cabecalho-painel {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid #f1f5f9;
        padding-bottom: 1rem;
    }

    .cabecalho-painel h2 {
        margin: 0;
        font-size: 1.25rem;
        color: #1e293b;
    }

    .status-badge {
        font-size: 0.8rem;
        font-weight: 600;
        background: #f8fafc;
        padding: 4px 8px;
        border-radius: 999px;
    }

    .grid-colunas {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .grid-colunas {
            grid-template-columns: 1fr 1fr;
        }
    }

    .coluna {
        background: #f8fafc;
        padding: 1rem;
        border-radius: 8px;
    }

    .titulo-coluna {
        font-size: 1rem;
        margin-top: 0;
        margin-bottom: 1rem;
        font-weight: 700;
    }

    .lista-ativos {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .item-moeda {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.75rem 0;
        border-bottom: 1px solid #e2e8f0;
        font-size: 0.95rem;
    }

    .item-moeda:last-child {
        border-bottom: none;
    }

    .moeda-info {
        display: flex;
        align-items: center;
        width: 30%;
    }

    /* CSS do ícone removido */

    .moeda-sigla {
        font-weight: 600;
        color: #334155;
    }

    .moeda-preco {
        font-weight: 500;
        color: #64748b;
        text-align: right;
    }

    .moeda-variacao {
        font-weight: 700;
        text-align: right;
        min-width: 70px;
    }

    .text-green { color: #16a34a; }
    .text-red { color: #dc2626; }
    .carregando { color: #94a3b8; font-style: italic; text-align: center; }
</style>