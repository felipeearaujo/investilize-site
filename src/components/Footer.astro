---
const today = new Date();
---

<footer>
    <div class="footer-container">
        <div class="footer-author">
            <div class="author-avatar">
                <span>FA</span>
            </div>
            <div class="author-info">
                <h4>Sobre o Autor</h4>
                <p>
                    <strong>Felipe Araújo</strong> é Mestrando em Administração pelo <strong>CCSA da UFPE</strong>, desenvolvedor e especialista em sistemas. 
                    Criou o Investilize para transformar dados técnicos em ferramentas práticas para investidores. 
                    Atua em Carpina, Pernambuco.
                </p>
            </div>
        </div>

        <hr class="footer-divider" />

        <nav class="footer-nav">
            <a href="/sobre/">Sobre</a>
            <a href="/contato/">Contato</a>
            <a href="/politica-de-privacidade/">Política de Privacidade</a>
            <a href="/termos-de-uso/">Termos de Uso</a>
        </nav>

        <div class="copyright">
            &copy; {today.getFullYear()} Felipe Araújo. Todos os direitos reservados.
        </div>
    </div>
</footer>

<style>
    footer {
        padding: 4rem 1rem 3rem 1rem;
        background: linear-gradient(var(--gray-gradient)) no-repeat;
        color: rgb(var(--gray));
        text-align: center;
        border-top: 1px solid rgba(var(--gray), 0.1);
    }

    .footer-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* ESTILO DA BIO */
    .footer-author {
        display: flex;
        align-items: center;
        gap: 2rem;
        text-align: left;
        margin-bottom: 2.5rem;
    }

    .author-avatar {
        width: 70px;
        height: 70px;
        background-color: #003d6b; /* Azul Marinho */
        color: white;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .author-info h4 {
        margin: 0 0 0.4rem 0;
        color: #003d6b;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .author-info p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .author-info strong {
        color: var(--accent); /* Azul Royal */
    }

    .footer-divider {
        border: 0;
        border-top: 1px solid rgba(var(--gray), 0.2);
        margin-bottom: 2rem;
    }

    .footer-nav {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .footer-nav a {
        color: rgb(var(--gray));
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        transition: color 0.2s ease;
    }

    .footer-nav a:hover {
        color: var(--accent);
        text-decoration: underline;
    }

    .copyright {
        font-size: 0.85rem;
        opacity: 0.8;
    }

    /* RESPONSIVIDADE PARA O CELULAR */
    @media (max-width: 720px) {
        .footer-author {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }
        .footer-nav {
            flex-wrap: wrap;
            gap: 1rem;
        }
    }
</style>