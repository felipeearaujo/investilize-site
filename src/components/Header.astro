---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import logo from 'src/assets/logo.svg';
---

<header>
    <nav>
        <a href="/"><Image src={logo} alt="Investilize" width="190" /></a>
        
        <div class="internal-links">
            <HeaderLink href="/noticias">Notícias</HeaderLink>
            <HeaderLink href="/blog">Blog</HeaderLink>
            
            <div class="dropdown-wrapper">
                <span class="menu-trigger">
                    Ferramentas <span class="arrow">▾</span>
                </span>
                
                <div class="dropdown-menu">
                    <a href="/ferramentas/taxometro">📊 Taxômetro Tesouro</a>
                    <a href="/ferramentas/tesouro-vs-bancao">🏦 Tesouro vs. Bancão</a>
                    <a href="/ferramentas/taxa-real">📈 Calculadora Taxa Real</a>
                    <a href="/ferramentas/poder-de-compra">💰 Poder de Compra</a>
                    <a href="/ferramentas/calculadora-preco-justo">💰Calculadora Preço Justo</a>
                    <a href="/ferramentas/independencia-financeira">💰Independência Financeira</a>
                    
                    
                    <hr /> <a href="/ferramentas/" style="font-weight: bold;">🔍 Ver Todas</a>
                </div>
            </div>

            <HeaderLink href="/sobre">Sobre</HeaderLink>
        </div>
        
        <div class="social-links">
            </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 0 1em;
        background: white;
        /* Sombra leve ajustada para o tom Marinho */
        box-shadow: 0 2px 8px rgba(0, 61, 107, 0.08); 
        position: relative;
        z-index: 1000;
    }
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .internal-links {
        display: flex;
        align-items: center;
    }

    /* --- ESTILO DOS LINKS --- */
    nav a {
        padding: 1em 0.5em;
        /* Alterado para Azul Marinho */
        color: #003d6b; 
        border-bottom: 4px solid transparent;
        text-decoration: none;
        display: inline-block;
        font-weight: 600;
    }
    
    nav a.active {
        text-decoration: none;
        /* Alterado para Azul Royal */
        border-bottom-color: #0167c2; 
    }

    /* --- ESTILO DO GATILHO DO MENU --- */
    .menu-trigger {
        padding: 1em 0.5em;
        /* Alterado para Azul Marinho */
        color: #003d6b; 
        border-bottom: 4px solid transparent;
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
        font-weight: 600;
        user-select: none;
    }

    .menu-trigger:hover,
    .dropdown-wrapper:hover .menu-trigger {
        /* Alterado para Verde Médio (Destaque de Sucesso) */
        border-bottom-color: #4bac40;
        color: #0167c2; 
    }

    /* --- DROPDOWN LÓGICA --- */
    .dropdown-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        height: 100%;
    }

    .dropdown-menu {
        display: none;
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%);
        background-color: white;
        min-width: 240px;
        box-shadow: 0 8px 16px rgba(0, 61, 107, 0.15);
        border-radius: 8px;
        padding: 8px 0;
        z-index: 1001;
        border: 1px solid #f0f0f0;
    }

    .dropdown-menu a {
        display: block;
        padding: 10px 16px;
        /* Texto das ferramentas em Marinho */
        color: #003d6b; 
        border-bottom: none;
        font-size: 0.95rem;
        text-align: left;
    }

    .dropdown-menu a:hover {
        /* Fundo suave e texto em Verde no hover */
        background-color: #f8fafc;
        color: #4bac40; 
    }

    .dropdown-wrapper:hover .dropdown-menu {
        display: block;
    }

    .social-links { display: flex; }

    @media (max-width: 720px) {
        .social-links { display: none; }
        nav { flex-wrap: wrap; }
        .internal-links { width: 100%; justify-content: center; }
    }
</style>