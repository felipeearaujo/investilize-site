---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import ArticleSchema from '../components/ArticleSchema.astro'; 
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqSchema from '../components/FaqSchema.astro';

// 1. IMPORTAÇÃO DOS DADOS DO BACEN
import indicadores from '../data/bacen.json';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, faqList, heroImageAlt } = Astro.props;

// 2. LÓGICA DE SUBSTITUIÇÃO DINÂMICA (Com Fallback para evitar erro de título vazio)
const selic = indicadores?.selic || "14.75";
const dynamicTitle = title ? title.replace('{selicAtual}', selic) : "Investilize";
const dynamicDescription = description ? description.replace('{selicAtual}', selic) : "Educação Financeira e Investimentos";

// 3. TRATAMENTO DA IMAGEM
const resolvedImage = (typeof heroImage === 'string' ? heroImage : heroImage?.src) || "https://investilize.com.br/logo.png";

---

<html lang="pt-br">
    <head>
    	<meta name="ezoic-site-verification" content="FEJWdNWd8kM54jgA3UKlWa7Q7OJipi" />
        <script data-cfasync="false" src="https://cmp.gatekeeperconsent.com/min.js"></script>
        <script data-cfasync="false" src="https://the.gatekeeperconsent.com/cmp.min.js"></script>

        <script async src="https://go.ezoic.net/ezoic/ezoic.js"></script>

        <BaseHead title={dynamicTitle} description={dynamicDescription} image={resolvedImage} />        
        
        <ArticleSchema
            title={dynamicTitle}
            description={dynamicDescription}
            publishDate={pubDate}
            imagePath={resolvedImage}
        />

        {faqList && <FaqSchema faqList={faqList} />}

        <script type="application/ld+json" is:inline>
        {
          "@context": "https://schema.org",
          "@type": "Organization",
          "name": "Investilize",
          "url": "https://investilize.com.br/",
          "logo": "https://investilize.com.br/logo.png"
        }
        </script>

        <style>
            main { width: calc(100% - 2em); max-width: 100%; margin: 0; }
            .hero-image { width: 100%; }
            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
                max-width: 100%;
                height: auto;
            }
            .prose {
                width: 720px;
                max-width: calc(100% - 2em);
                margin: auto;
                padding: 1em;
                color: rgb(var(--gray-dark));
            }
            .title { margin-bottom: 1em; padding: 1em 0; text-align: center; line-height: 1; }
            .title h1 { margin: 0 0 0.5em 0; }
            .date { margin-bottom: 0.5em; color: rgb(var(--gray)); }
            .last-updated-on { font-style: italic; }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {heroImage && <Image
                        width={1020}
                        height={510}
                        src={heroImage}
                        alt={heroImageAlt || dynamicTitle}
                        sizes="(max-width: 720px) 100vw, 720px"
                    />}
                </div>
                <div id="ezoic-pub-ad-placeholder-100"></div>
                <div class="prose">
                    <Breadcrumbs />
                    <div class="title">
                        <div class="date">
                            {pubDate && <FormattedDate date={pubDate} />}
                            {updatedDate && (
                                <div class="last-updated-on">
                                    Atualizado em <FormattedDate date={updatedDate} />
                                </div>
                            )}
                        </div>
                        <h1>{dynamicTitle}</h1>
                        <hr />
                    </div>
                    
                    <div id="ezoic-pub-ad-placeholder-101"></div>
                    <slot />
                    
                    <div id="ezoic-pub-ad-placeholder-102"></div>
                    
                    <div id="ezoic-pub-ad-placeholder-103"></div>
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>