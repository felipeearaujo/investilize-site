---
import { SEO } from "astro-seo";
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;

// 1. Configuração da URL Canônica
const canonicalURL = new URL(Astro.url.pathname, "https://investilize.com.br").toString();

// 2. TRATAMENTO DE SEGURANÇA PARA A DATA (Evita o erro toISOString)
const safeDate = frontmatter.pubDate ? new Date(frontmatter.pubDate) : null;
const isoPubDate = (safeDate && !isNaN(safeDate.getTime())) ? safeDate.toISOString() : undefined;

// 3. FALLBACKS OBRIGATÓRIOS PARA O ASTRO-SEO (Evita erro de build na Netlify)
const safeTitle = frontmatter.title || "Notícias de Economia | Investilize";
const safeDescription = frontmatter.description || "Acompanhe as últimas atualizações sobre economia, finanças e mercado financeiro.";
const safeImage = frontmatter.heroImage || "https://investilize.com.br/logo.png";
---

<html lang="pt-BR">
    <head>
        <meta name="referrer" content="no-referrer">

        <SEO
            title={safeTitle}
            description={safeDescription}
            canonical={canonicalURL}
            openGraph={{
                basic: {
                    title: safeTitle,
                    type: "article",
                    image: safeImage,
                },
                article: {
                    publishedTime: isoPubDate,
                    authors: ["Investilize"],
                    section: "Economia"
                },
                optional: {
                    description: safeDescription,
                    siteName: "Investilize",
                }
            }}
            twitter={{
                card: "summary_large_image",
                site: "@investilize",
                creator: "@felipearaujo",
                title: safeTitle,
                description: safeDescription,
                image: safeImage,
            }}
            extend={{
                meta: [
                    { name: "author", content: "Agência Brasil" },
                    { name: "publish_date", content: frontmatter.pubDate || "" },
                ],
            }}
        />
        
        <BaseHead title={safeTitle} description={safeDescription} />
    </head>
    <body>
        <Header />
        <main>
            <article>
                <header class="news-header">
                    <span class="category">Economia Nacional</span>
                    <h1>{frontmatter.title}</h1>
                    <p class="source-credit">Fonte: Agência Brasil | Publicado em {frontmatter.pubDate}</p>
                </header>
                
                {frontmatter.heroImage && (
                    <div class="imagem-destaque">
                        <img 
                            src={frontmatter.heroImage} 
                            alt={safeTitle} 
                            referrerpolicy="no-referrer"
                            loading="lazy"
                        />
                    </div>
                )}

                <div class="content">
                    <slot /> 
                </div>

                <footer class="news-footer">
                    <p><em>Este conteúdo foi republicado via Agência Brasil sob licença Creative Commons. <a href={frontmatter.originalUrl} target="_blank" rel="noopener noreferrer">Ver original.</a></em></p>
                </footer>
            </article>
        </main>
        <Footer />
    </body>
</html>

<style>
    /* Estilo jornalístico e limpo */
    .news-header { margin-bottom: 2rem; border-bottom: 1px solid #eee; padding-bottom: 1rem; }
    .category { color: #4bac40; font-weight: 800; text-transform: uppercase; font-size: 0.8rem; }
    .source-credit { color: #64748b; font-size: 0.9rem; font-style: italic; }
    .news-footer { margin-top: 3rem; padding: 1.5rem; background: #f8fafc; border-radius: 8px; font-size: 0.85rem; }
    .content { line-height: 1.6; color: #334155; }
    
    /* 🚀 Estilos para a nova imagem de destaque */
    .imagem-destaque { margin-bottom: 2rem; width: 100%; }
    .imagem-destaque img { 
        width: 100%; 
        max-height: 500px; 
        object-fit: cover; 
        border-radius: 8px; 
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    }
</style>