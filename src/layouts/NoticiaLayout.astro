---
import { SEO } from "astro-seo";
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const { frontmatter } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, "https://investilize.com.br").toString();

// 1. Identificação do Slug e da Imagem
const slug = Astro.url.pathname.split('/').filter(Boolean).pop();
let rawImage = frontmatter.capa || frontmatter.heroImage || "";
let imageName = String(rawImage).split('/').pop();

// 2. Lógica de Fallback de Imagem
let displayImage = "";
if (!imageName || imageName === "" || imageName.includes("undefined") || imageName.includes("default-investilize")) {
    displayImage = `/images/noticias/${slug}.webp`;
} else {
    displayImage = `/images/noticias/${imageName}`;
}

const fullImagePath = `https://investilize.com.br${displayImage}`;
---

<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <BaseHead title={frontmatter.title} description={frontmatter.description} />
    
    <SEO 
        title={frontmatter.title}
        description={frontmatter.description}
        canonical={canonicalURL}
        openGraph={{
            basic: {
                title: frontmatter.title,
                type: "article",
                image: fullImagePath,
                url: canonicalURL,
            },
            article: {
                publishedTime: frontmatter.pubDate,
                authors: ["Felipe Araújo"],
                section: "Economia"
            }
        }}
        twitter={{
            card: "summary_large_image",
            site: "@investilize",
            title: frontmatter.title,
            description: frontmatter.description,
            image: fullImagePath,
        }}
    />

    <script is:inline>
        function handleImageError(img) {
            const fallback = "/images/noticias/default-investilize.webp";
            if (img.src.includes('.webp')) {
                img.src = img.src.replace('.webp', '.jpg');
            } else if (img.src.includes('.jpg')) {
                img.src = img.src.replace('.jpg', '.png');
            } else {
                img.src = fallback;
                img.onerror = null;
            }
        }
    </script>
</head>

<body>
    <Header />
    <main style="width: 800px; max-width: 95%; margin: 2rem auto;">
        <article>
            <Breadcrumbs />
            
            <h1 style="color: #003d6b; font-size: 2.2rem; margin-top: 1rem;">{frontmatter.title}</h1>
            
            <div style="margin: 2rem 0;">
                <img 
                    src={displayImage} 
                    alt={frontmatter.title} 
                    style="width: 100%; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);"
                    onerror="handleImageError(this)"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>

            <div class="content">
                <slot />
            </div>
        </article>
    </main>
    <Footer />
</body>
</html>