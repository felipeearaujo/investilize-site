---
import { SEO } from "astro-seo";
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { frontmatter } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, "https://investilize.com.br").toString();

const safeDate = frontmatter.pubDate ? new Date(frontmatter.pubDate) : null;
const isoPubDate = (safeDate && !isNaN(safeDate.getTime()))
  ? safeDate.toISOString()
  : undefined;

const safeTitle = frontmatter.title || "Notícias de Economia | Investilize";
const safeDescription = frontmatter.description || "Acompanhe as últimas atualizações sobre economia e mercado.";

// Melhoria na lógica da imagem:
const rawImage = frontmatter.heroImage || "";
const isGif = rawImage.includes(".gif") || rawImage.includes("loading");

let safeImage = "https://investilize.com.br/logo.png";

if (rawImage && !isGif) {
    if (rawImage.startsWith("http")) {
        safeImage = rawImage;
    } else {
        safeImage = `https://investilize.com.br${rawImage.startsWith('/') ? '' : '/'}${rawImage}`;
    }
}
---

<html lang="pt-BR">
<head>
    <meta name="referrer" content="no-referrer">
    <BaseHead />

    <SEO
      title={safeTitle}
      description={safeDescription}
      canonical={canonicalURL}
      openGraph={{
        basic: {
          title: safeTitle,
          type: "article",
          image: safeImage,
          url: canonicalURL
        },
        article: {
          publishedTime: isoPubDate,
          authors: ["Investilize"],
          section: "Economia"
        }
      }}
      twitter={{
        card: "summary_large_image",
        title: safeTitle,
        image: safeImage
      }}
    />

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "NewsArticle",
      "headline": safeTitle,
      "image": [safeImage],
      "datePublished": isoPubDate,
      "author": { "@type": "Organization", "name": "Agência Brasil" }
    }
    </script>
</head>

<body>
    <Header />
    <main>
        <article>
            <header class="news-header">
                <span class="category">Economia Nacional</span>
                <h1>{safeTitle}</h1>
                <p class="source-credit">
                    Fonte: Agência Brasil | Publicado em {safeDate?.toLocaleDateString("pt-BR")}
                </p>
            </header>

            {safeImage && safeImage !== "https://investilize.com.br/logo.png" && (
                <div class="imagem-destaque">
                    <img 
                        src={safeImage} 
                        alt={safeTitle} 
                        referrerpolicy="no-referrer"
                        loading="eager" 
                        decoding="async"
                    />
                </div>
            )}

            <div class="content">
                <slot />
            </div>

            <footer class="news-footer">
                <p>
                    <em>Este conteúdo foi republicado via Agência Brasil. <a href={frontmatter.originalUrl} target="_blank">Ver original</a></em>
                </p>
            </footer>
        </article>
    </main>
    <Footer />
</body>
</html>

<style>
    .news-header { margin-bottom: 2rem; border-bottom: 1px solid #eee; padding-bottom: 1rem; }
    .category { color: #4bac40; font-weight: 800; text-transform: uppercase; font-size: .8rem; }
    .source-credit { color: #64748b; font-size: .9rem; font-style: italic; }
    .news-footer { margin-top: 3rem; padding: 1.5rem; background: #f8fafc; border-radius: 8px; }
    .content { line-height: 1.6; color: #334155; }

    .imagem-destaque { margin-bottom: 2rem; width: 100%; }
    .imagem-destaque img { 
        width: 100%; 
        max-height: 500px; 
        object-fit: cover; 
        border-radius: 8px; 
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); 
    }

    /* Ocultar apenas imagens duplicadas que venham soltas no início do markdown */
    /* Isso evita esconder a imagem dentro da div de análise técnica */
    .content > :global(img:first-child) {
        display: none !important;
    }
</style>