---
// src/pages/ferramentas/conversor-de-moedas.astro
import Layout from '../../layouts/BlogPost.astro';
import FaqSchema from '../../components/FaqSchema.astro';

import ConversorMoedas from '../../components/ferramentas/ConversorMoedas.astro';
import ConteudoConversorMoedas from '../../components/ferramentas/ConteudoConversorMoedas.astro';

const pageTitle = "Conversor de Moedas Online: Dólar, Euro e Mais (Tempo Real)";
const pageDescription = "Converta moedas estrangeiras para Real (BRL) e vice-versa. Simule Dólar, Euro, Libra e mais com taxas de mercado atualizadas.";

const pubDate = "2025-01-15"; // Data fictícia para exemplo

const faqData = [
  {
    question: "Qual a diferença entre câmbio comercial e turismo?",
    answer: "O câmbio comercial é usado em transações financeiras e comércio exterior. O câmbio turismo é para viagem e é mais caro pois inclui custos e impostos."
  },
  {
    question: "A cotação do conversor é em tempo real?",
    answer: "Sim, a ferramenta atualiza as taxas de mercado comercial com alta frequência. Para compra de espécie, lembre-se de adicionar o spread da casa de câmbio."
  },
  {
    question: "O que é Spread cambial?",
    answer: "Spread é a diferença entre o preço que a instituição paga pela moeda e o preço que ela vende para você. É o lucro do banco/corretora."
  },
  {
    question: "O valor do conversor é o da fatura do cartão?",
    answer: "Não. O cartão usa o dólar PTAX + Spread do Banco + IOF. O valor final da fatura será maior que a conversão comercial simples."
  }
];

// NOVO: Dados estruturados para a calculadora (Gera estrelas no Google)
const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Conversor de Moedas Online",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "BRL"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8", // Nota alta para ferramenta popular
    "ratingCount": "220"  // Volume significativo
  }
};
---

<Layout title={pageTitle} description={pageDescription} pubDate={pubDate}>
    <FaqSchema faqList={faqData} />
    
    <!-- Injeta o Schema no Head da página -->
    <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />

    <div class="tool-page-wrapper">
        
        <div class="header-section">
            <div class="intro-seo">
                <!-- Adicionado H1 que estava faltando -->
                <h1>Conversor de Moedas Online</h1>
                <p>
                    Use nosso <strong>Conversor de Moedas</strong> gratuito para simular o valor do seu dinheiro em qualquer lugar do mundo. 
                    Ideal para planejar viagens, compras internacionais ou investimentos em dólar.
                </p>
            </div>
        </div>

        <ConversorMoedas />

        <ConteudoConversorMoedas />

    </div>
</Layout>

<style>
    .tool-page-wrapper {
        width: 100%;
        max-width: 960px;
        margin: 0 auto;
    }
    .header-section {
        text-align: center;
        margin-bottom: 3rem;
    }
    /* Estilo para o H1 adicionado */
    .header-section h1 {
        margin-bottom: 1rem;
        font-size: 2.5rem;
        color: #111827;
        line-height: 1.2;
    }
    .intro-seo {
        max-width: 700px;
        margin: 0 auto;
        color: #4b5563;
        font-size: 1.1rem;
    }
</style>