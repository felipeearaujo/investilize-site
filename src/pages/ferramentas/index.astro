---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const pageTitle = "Ferramentas Financeiras Gratuitas 2026 | Calculadoras e Simuladores | Investilize";
const pageDescription = "Calculadoras financeiras gratuitas para investidores: Juros Compostos, Preço Justo (Graham/Bazin), Reserva de Emergência, Taxa Real, IR Mensal e muito mais. Dados oficiais.";

const categorias = [
  {
    id: "comecar",
    nome: "Para Começar",
    subtitulo: "Planejamento pessoal e primeiros passos no mundo dos investimentos",
    cor: "#0ea5e9",
    corBg: "#f0f9ff",
    items: [
      {
        titulo: "Calculadora de Juros Compostos",
        desc: "Descubra a bola de neve financeira: simule seu crescimento patrimonial com aportes mensais.",
        href: "/ferramentas/juros-compostos",
        icon: "📈",
        destaque: true,
      },
      {
        titulo: "Reserva de Emergência",
        desc: "Quanto precisa guardar hoje? Calcule sua meta de segurança financeira por perfil CLT ou Autônomo.",
        href: "/ferramentas/calculadora-reserva-emergencia",
        icon: "🛡️",
        destaque: true,
      },
      {
        titulo: "Independência Financeira (FIRE)",
        desc: "Calcule quanto tempo falta para viver de renda e descobrir sua liberdade financeira.",
        href: "/ferramentas/independencia-financeira",
        icon: "🏖️",
      },
      {
        titulo: "Perfil do Investidor",
        desc: "Conservador, moderado ou arrojado? Descubra qual estratégia se encaixa no seu perfil.",
        href: "/ferramentas/investimentos",
        icon: "🧭",
      },
      {
        titulo: "Poder de Compra (IPCA)",
        desc: "Veja o impacto real da inflação: quanto seu dinheiro perdeu de valor ao longo do tempo.",
        href: "/ferramentas/poder-de-compra",
        icon: "🛒",
      },
      {
        titulo: "Conversor de Moedas",
        desc: "Cotação atualizada de Dólar, Euro e Libra em tempo real para planejamento de viagens e investimentos.",
        href: "/ferramentas/conversor-de-moedas",
        icon: "💱",
      },
    ]
  },
  {
    id: "acoes",
    nome: "Para Analisar Ações",
    subtitulo: "Análise fundamentalista e cotações para investidores em renda variável",
    cor: "#8b5cf6",
    corBg: "#f5f3ff",
    items: [
      {
        titulo: "Preço Justo (Fórmula Graham & Bazin)",
        desc: "Calcule o Valor Intrínseco e a Margem de Segurança de ações com as fórmulas clássicas.",
        href: "/ferramentas/calculadora-preco-justo",
        icon: "💰",
        destaque: true,
      },
      {
        titulo: "Cotação Atualizada de Ações",
        desc: "Busque a cotação atualizada de qualquer ação da B3 (PETR4, VALE3) ou mercado americano.",
        href: "/ferramentas/cotacao-acoes",
        icon: "📊",
      },
      {
        titulo: "Mercado Cripto ao Vivo",
        desc: "Preço do Bitcoin 2026 e maiores altas e quedas do mercado cripto nas últimas 24 horas.",
        href: "/ferramentas/mercado-cripto",
        icon: "🚀",
      },
    ]
  },
  {
    id: "renda-fixa",
    nome: "Para Renda Fixa",
    subtitulo: "Simuladores precisos para títulos públicos, CDBs, impostos e rentabilidade real",
    cor: "#16a34a",
    corBg: "#f0fdf4",
    items: [
      {
        titulo: "Taxa Real de Juros (Equação de Fisher)",
        desc: "Descubra a sua rentabilidade real: quanto você ganha de verdade acima da inflação (IPCA).",
        href: "/ferramentas/taxa-real",
        icon: "📉",
        destaque: true,
      },
      {
        titulo: "Taxômetro Tesouro Direto",
        desc: "Taxas do Tesouro Selic 2026 e títulos IPCA+ em tempo real. Entenda a marcação a mercado.",
        href: "/ferramentas/taxometro-tesouro",
        icon: "🏛️",
      },
      {
        titulo: "Tesouro vs Bancão",
        desc: "Tesouro Selic ou CDB de bancão? Compare o rendimento real de cada opção lado a lado.",
        href: "/ferramentas/tesouro-vs-bancao",
        icon: "🏦",
      },
      {
        titulo: "Comparador de Renda Fixa",
        desc: "Compare CDB, LCI, LCA e Tesouro numa única simulação. Qual rende mais no longo prazo?",
        href: "/ferramentas/comparador-renda-fixa",
        icon: "⚖️",
      },
      {
        titulo: "Calculadora de IR Mensal (DARF)",
        desc: "Simule o Imposto de Renda Mensal pela tabela progressiva 2026. Evite multas no Carnê-Leão.",
        href: "/ferramentas/calculadora-ir-mensal",
        icon: "🧾",
      },
    ]
  }
];
---

<!doctype html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <BaseHead title={pageTitle} description={pageDescription} />
</head>
<body>
    <Header />
    <main class="hub-main">
        <div class="container">
            <Breadcrumbs />
            <div class="hub-header">
                <p class="hub-eyebrow">🧰 Investilize · Ferramentas</p>
                <h1>Calculadoras Financeiras Gratuitas</h1>
                <p class="hub-sub">Simuladores baseados em dados oficiais (Banco Central, B3 e CVM) para você investir com inteligência em 2026.</p>
            </div>

            {categorias.map(cat => (
                <section class="categoria-section">
                    <div class="categoria-header" style={`border-left-color: ${cat.cor};`}>
                        <div>
                            <h2 class="categoria-nome" style={`color: ${cat.cor};`}>{cat.nome}</h2>
                            <p class="categoria-sub">{cat.subtitulo}</p>
                        </div>
                        <span class="categoria-badge" style={`background: ${cat.corBg}; color: ${cat.cor};`}>
                            {cat.items.length} ferramentas
                        </span>
                    </div>

                    <div class="grid-ferramentas">
                        {cat.items.map(item => (
                            <a href={item.href} class={`card-ferramenta ${item.destaque ? 'card-destaque' : ''}`}
                               style={item.destaque ? `--accent: ${cat.cor}; --accent-bg: ${cat.corBg};` : `--accent: ${cat.cor}; --accent-bg: ${cat.corBg};`}>
                                {item.destaque && <span class="badge-destaque">⭐ Mais usado</span>}
                                <span class="card-icon" style={`background: ${cat.corBg};`}>{item.icon}</span>
                                <div class="card-body">
                                    <h3>{item.titulo}</h3>
                                    <p>{item.desc}</p>
                                    <span class="btn-text" style={`color: ${cat.cor};`}>Acessar simulador →</span>
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </main>
    <Footer />

    <style is:global>
        :root {
            --navy: #003d6b;
            --text-main: #0f172a;
            --text-muted: #475569;
            --bg-light: #f8fafc;
            --border-color: #e2e8f0;
        }

        .hub-main {
            width: 100%;
            background-color: var(--bg-light);
            padding: 3rem 0 5rem;
            min-height: 80vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }

        /* Cabeçalho da página */
        .hub-header {
            text-align: center;
            margin: 1rem 0 4rem;
        }
        .hub-eyebrow {
            font-size: 0.85rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #64748b;
            margin-bottom: 0.75rem;
        }
        .hub-header h1 {
            color: var(--navy);
            font-size: 2.8rem;
            font-weight: 900;
            margin: 0 0 1rem;
            line-height: 1.15;
        }
        .hub-sub {
            color: var(--text-muted);
            font-size: 1.15rem;
            max-width: 650px;
            margin: 0 auto;
            line-height: 1.6;
        }

        /* Seção de categoria */
        .categoria-section {
            margin-bottom: 4.5rem;
        }
        .categoria-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            border-left: 5px solid;
            padding-left: 1rem;
            margin-bottom: 2rem;
        }
        .categoria-nome {
            font-size: 1.6rem;
            font-weight: 900;
            margin: 0 0 0.25rem;
        }
        .categoria-sub {
            color: var(--text-muted);
            font-size: 0.95rem;
            margin: 0;
        }
        .categoria-badge {
            font-size: 0.8rem;
            font-weight: 700;
            padding: 0.3rem 0.75rem;
            border-radius: 30px;
            white-space: nowrap;
            flex-shrink: 0;
            margin-top: 4px;
        }

        /* Grid */
        .grid-ferramentas {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 1.25rem;
        }

        /* Card */
        .card-ferramenta {
            background: white;
            padding: 1.5rem;
            border-radius: 16px;
            border: 1.5px solid var(--border-color);
            text-decoration: none !important;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            transition: all 0.25s ease;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
            position: relative;
            overflow: hidden;
        }
        .card-ferramenta:hover {
            border-color: var(--accent);
            transform: translateY(-5px);
            box-shadow: 0 16px 24px -6px rgba(0,0,0,0.1);
        }
        .card-destaque {
            border-color: var(--accent) !important;
            background: linear-gradient(160deg, white 60%, var(--accent-bg) 100%);
        }

        /* Badge "Mais usado" */
        .badge-destaque {
            position: absolute;
            top: 12px;
            right: 12px;
            font-size: 0.7rem;
            font-weight: 800;
            background: var(--accent-bg);
            color: var(--accent);
            padding: 2px 8px;
            border-radius: 20px;
            border: 1px solid var(--accent);
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        /* Ícone de alto contraste */
        .card-icon {
            font-size: 2rem;
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 14px;
            flex-shrink: 0;
            filter: drop-shadow(0 2px 4px rgba(0,0,0,0.08));
        }

        .card-body {
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .card-body h3 {
            color: var(--text-main);
            margin: 0 0 0.5rem;
            font-size: 1.05rem;
            font-weight: 800;
            line-height: 1.3;
        }
        .card-body p {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin: 0;
            line-height: 1.55;
            flex: 1;
        }
        .btn-text {
            margin-top: 1rem;
            font-size: 0.875rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
            transition: gap 0.2s;
        }
        .card-ferramenta:hover .btn-text {
            gap: 8px;
        }

        /* Responsividade */
        @media (max-width: 768px) {
            .hub-header h1 { font-size: 2rem; }
            .grid-ferramentas { grid-template-columns: 1fr; }
            .categoria-header { flex-direction: column; }
            .container { padding: 0 1rem; }
            .hub-main { padding: 2rem 0 3rem; }
        }
    </style>
</body>
</html>