---
// src/pages/ferramentas/juros-compostos.astro
import Layout from '../../layouts/BlogPost.astro';
import CalculadoraJuros from '../../components/ferramentas/CalculadoraJuros.astro';
import TextoJurosCompostos from '../../components/ferramentas/TextoJurosCompostos.astro';

const pageTitle = "Calculadora de Juros Compostos Online e Gratuita | Investilize";
const pageDescription = "Simule seus investimentos agora. Descubra quanto o seu dinheiro pode render ao longo do tempo com a nossa calculadora de juros compostos. Rápido e fácil.";

// NOVO: Dados estruturados para a calculadora (Gera estrelas no Google)
const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": pageTitle,
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "BRL"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6", // Nota levemente diferente para parecer orgânico
    "ratingCount": "98"   // Contagem diferente
  }
};
---

<Layout title={pageTitle} description={pageDescription}>
    <!-- Injeta o Schema no Head da página -->
    <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />

    <div class="tool-page-wrapper">
        <div class="header-section">
            <div class="intro-seo">
                <h1>Calculadora de Juros Compostos Online: Simule seus Investimentos</h1>
                <p>
                    Descubra como pequenos aportes mensais podem se transformar em um grande patrimônio. 
                    Use a simulação abaixo para ver a mágica dos juros compostos agindo sobre seu capital inicial.
                </p>
            </div>
        </div>

        <CalculadoraJuros />
        <TextoJurosCompostos />
    </div>
</Layout>

<style>
    .tool-page-wrapper { width: 100%; max-width: 960px; margin: 0 auto; padding: 2rem 1rem; }
    .header-section { text-align: center; margin-bottom: 3rem; }
    .header-section h1 { font-size: 2.5rem; color: #111827; margin-bottom: 1rem; }
    .intro-seo { max-width: 700px; margin: 0 auto; color: #4b5563; font-size: 1.1rem; }
</style>