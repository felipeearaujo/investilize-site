---
import Layout from '../../layouts/BlogPost.astro';
import CalculadoraJuros from '../../components/ferramentas/CalculadoraJuros.astro';
import TextoJurosCompostos from '../../components/ferramentas/TextoJurosCompostos.astro'; // NOME ALTERADO

const pageTitle = "Calculadora de Juros Compostos com Aportes Mensais";
const pageDescription = "Simule o poder dos juros compostos com aportes mensais. Veja quanto seu investimento pode render no longo prazo e planeje sua independência financeira.";
---

<Layout title={pageTitle} description={pageDescription}>
    <div class="tool-page-wrapper">
        <div class="header-section">
            <div class="intro-seo">
                <h1>Calculadora de Juros Compostos com Aportes Mensais</h1>
                <p>
                    Descubra como pequenos aportes mensais podem se transformar em um grande patrimônio. 
                    Use a simulação abaixo para ver a mágica dos juros compostos agindo sobre seu capital inicial.
                </p>
            </div>
        </div>

        <CalculadoraJuros />
        <!-- Componente com nome corrigido -->
        <TextoJurosCompostos />
    </div>
</Layout>

<style>
    .tool-page-wrapper { width: 100%; max-width: 960px; margin: 0 auto; padding: 2rem 1rem; }
    .header-section { text-align: center; margin-bottom: 3rem; }
    .header-section h1 { font-size: 2.5rem; color: #111827; margin-bottom: 1rem; }
    .intro-seo { max-width: 700px; margin: 0 auto; color: #4b5563; font-size: 1.1rem; }
</style>