---
// src/pages/ferramentas/independenciafinanceira.astro
import Layout from '../../layouts/BlogPost.astro';
import FaqSchema from '../../components/FaqSchema.astro';
import IndependenciaFinanceira from '../../components/ferramentas/IndependenciaFinanceira.astro';
import ConteudoIndependencia from '../../components/ferramentas/ConteudoIndependencia.astro';

const pageTitle = "Calculadora de Independência Financeira (FIRE): Quanto tempo falta?";
const pageDescription = "Descubra quando você poderá se aposentar. Simule seu patrimônio necessário, taxa de poupança e tempo para viver de renda com nossa calculadora FIRE gratuita.";

const pubDate = new Date("2025-01-15"); // Data fictícia para exemplo

const faqData = [
  {
    question: "Quanto dinheiro preciso para viver de renda?",
    answer: "Geralmente, você precisa acumular cerca de 300 vezes o seu custo de vida mensal (Regra dos 4% ao ano)."
  },
  {
    question: "O que é o movimento FIRE?",
    answer: "Sigla para 'Financial Independence, Retire Early'. É um movimento de pessoas que buscam alta taxa de poupança para se aposentar jovens."
  },
  {
    question: "Onde investir para aposentadoria?",
    answer: "Ativos que geram renda passiva e protegem da inflação, como Tesouro IPCA+, Fundos Imobiliários (FIIs) e Ações de Dividendos."
  }
];

// NOVO: Dados estruturados (Schema) para a calculadora principal
const toolSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Calculadora de Independência Financeira",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "BRL"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.9", // Nota alta para ferramenta principal
    "ratingCount": "310"  // Maior volume de avaliações
  }
};
---

<Layout title={pageTitle} description={pageDescription} pubDate={pubDate}>
    <FaqSchema faqList={faqData} />
    
    <!-- Injeta o Schema no Head da página -->
    <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} />

    <div class="tool-page-wrapper">
        
        <div class="header-section">
            <div class="intro-seo">
                <!-- Adicionado H1 que estava faltando -->
                <h1>Calculadora de Independência Financeira (FIRE)</h1>
                <p>
                    O sonho de <strong>Viver de Renda</strong> é possível, mas exige planejamento. Nossa calculadora utiliza a matemática financeira 
                    para mostrar exatamente quanto tempo e dinheiro faltam para você conquistar sua <strong>Liberdade Financeira</strong>.
                </p>
            </div>
        </div>

        <independencia-financeira />

        <ConteudoIndependencia />

    </div>
</Layout>

<style>
    .tool-page-wrapper {
        width: 100%;
        max-width: 960px;
        margin: 0 auto;
    }
    .header-section {
        text-align: center;
        margin-bottom: 3rem;
    }
    /* Estilo para o H1 adicionado */
    .header-section h1 {
        font-size: 2.5rem;
        color: #111827;
        margin-bottom: 1rem;
        line-height: 1.2;
    }
    .intro-seo {
        max-width: 700px;
        margin: 0 auto;
        color: #4b5563;
        font-size: 1.1rem;
    }
</style>