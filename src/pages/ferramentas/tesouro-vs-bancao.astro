---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqSchema from '../../components/FaqSchema.astro';

import TesouroVsBancao from '../../components/ferramentas/TesouroVsBancao.astro';
import ConteudoTesouroBancao from '../../components/ferramentas/ConteudoTesouroBancao.astro';

const pageTitle = "Tesouro Selic vs. CDB: Qual rende mais? | Comparador Investilize";
const pageDescription = "Compare a rentabilidade real entre o Tesouro Selic e o CDB do seu banco. Calcule o ganho líquido já descontando o Imposto de Renda.";

const dadosFaq = [
  {
    question: "O que é melhor: Tesouro Selic ou CDB?",
    answer: "Depende da taxa oferecida. Geralmente, um CDB precisa render acima de 100% do CDI para superar o Tesouro Selic após as taxas da B3."
  },
  {
    question: "O CDB tem garantia?",
    answer: "Sim, os CDBs são garantidos pelo FGC em até R$ 250 mil. Já o Tesouro Selic é garantido pelo próprio Governo Federal."
  }
];
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <BaseHead title={pageTitle} description={pageDescription} />
        <FaqSchema faqList={dadosFaq} />
        <style>
            main { width: 960px; max-width: calc(100% - 2em); margin: 0 auto; padding: 3em 1em; }
            h1 { text-align: center; color: #003d6b; font-size: 2.5rem; margin-bottom: 1rem; }
            .intro-text { text-align: center; color: #4b5563; margin-bottom: 2rem; max-width: 700px; margin: 0 auto; }
            .spacer { margin-bottom: 4rem; }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <Breadcrumbs />
            <h1>{pageTitle}</h1>
            <p class="intro-text">
                Descubra se o investimento oferecido pelo seu banco vale a pena comparado à segurança do Tesouro Nacional.
            </p>

            <TesouroVsBancao />
            <div class="spacer"></div>
            <ConteudoTesouroBancao />
        </main>
        <Footer />
    </body>
</html>