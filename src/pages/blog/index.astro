---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

// 1. IMPORTAR DADOS DO BANCO CENTRAL
// Subimos dois níveis (../../) para sair de 'blog' e 'pages' e chegar em 'data'
import indicadores from '../../data/bacen.json';
const selic = indicadores?.selic || "13.25";

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const pageDescription = "Explore artigos, guias e insights atualizados em nosso blog. O conhecimento que você precisa para se aprofundar nos temas mais importantes para você. Leia agora!";
---

<!doctype html>
<html lang="pt-br">
    <head>
        <BaseHead title={SITE_TITLE} description={pageDescription} />
        <style>
    main {
        width: 960px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 3em 1em;
    }
    ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style-type: none;
        margin: 0;
        padding: 0;
    }
    ul li {
        /* O segredo: 'border-box' faz o padding não aumentar o tamanho do card */
        box-sizing: border-box; 
        width: calc(50% - 1rem);
        background: #ffffff;
        padding: 1.5rem; /* Aumentei um pouco para respirar melhor */
        border-radius: 16px;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    /* Se você quiser que o primeiro post NÃO seja gigante, apague este bloco abaixo */
    ul li:first-child {
        width: 100%;
        margin-bottom: 1rem;
        text-align: center;
    }
    ul li:first-child img {
        width: 100%;
    }

    ul li img {
        margin-bottom: 1rem;
        border-radius: 12px;
        width: 100%; /* Garante que a imagem siga o card */
        height: auto;
        object-fit: cover;
    }
    
    ul li a {
        display: block;
        text-decoration: none;
    }

    .title {
        margin: 0.5rem 0;
        color: #003d6b; 
        line-height: 1.2;
        font-weight: 800;
        font-size: 1.5rem; /* Tamanho ajustado para o card */
    }

    .date {
        margin: 0;
        color: #475569; 
        font-size: 0.9rem;
    }

    ul li:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    ul li a:hover .title {
        color: #0167c2; 
    }

    /* Responsividade para Celular */
    @media (max-width: 720px) {
        ul {
            gap: 1.5rem;
        }
        ul li {
            width: 100% !important; /* Em telas pequenas, volta a ser uma coluna */
        }
    }
</style>
    </head>
    <body>
        <Header />
        <main>
            <section>
                <ul>
                    {
                        posts.map((post) => {
                            // 2. LÓGICA DE SUBSTITUIÇÃO: Muda o texto bruto pelo valor real
                            const dynamicTitle = post.data.title.replace('{selicAtual}', selic);

                            return (
                                <li>
                                    <a href={`/blog/${post.id.replace(/\.[^/.]+$/, "")}/`}>
                                        {post.data.heroImage && (
                                            <Image 
                                                width={720} 
                                                height={360} 
                                                src={post.data.heroImage} 
                                                alt={post.data.heroImageAlt || dynamicTitle} 
                                                loading="lazy"
                                            />
                                        )}
                                        <h4 class="title">{dynamicTitle}</h4>
                                        <p class="date">
                                            <FormattedDate date={post.data.pubDate} />
                                        </p>
                                    </a>
                                </li>
                            )
                        })
                    }
                </ul>
            </section>
        </main>
        <Footer />
    </body>
</html>