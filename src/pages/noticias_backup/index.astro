---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const pageTitle = "Notícias Económicas e Financeiras | Investilize";
const pageDescription = "Fique por dentro dos principais acontecimentos que movimentam o mercado financeiro, economia nacional e indicadores oficiais.";

// 1. Buscamos TODOS os arquivos .md dentro desta mesma pasta
const posts = await Astro.glob('./*.md');

// 2. Ordenamos pela data de publicação (do mais novo para o mais antigo)
const noticias = posts.sort(
    (a, b) => new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime()
);
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <BaseHead title={pageTitle} description={pageDescription} />
        <style>
            main {
                width: 1000px;
                max-width: calc(100% - 2em);
                margin: 0 auto;
                padding: 3em 1em;
            }
            .news-hub-header { text-align: center; margin-bottom: 4rem; }
            .news-hub-header h1 { color: #003d6b; font-size: 2.8rem; font-weight: 800; margin-bottom: 0.5rem; }
            .news-hub-header p { color: #64748b; font-size: 1.2rem; }
            .news-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem; list-style: none; padding: 0; }
            .news-card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; transition: all 0.3s ease; display: flex; flex-direction: column; overflow: hidden; }
            .news-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0, 61, 107, 0.08); border-color: #0167c2; }
            .news-card a { text-decoration: none; display: flex; flex-direction: column; height: 100%; color: inherit; }
            .news-image { width: 100%; height: 200px; object-fit: cover; }
            .news-content { padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column; }
            .news-meta { display: flex; align-items: center; gap: 10px; font-size: 0.8rem; color: #4bac40; font-weight: 700; text-transform: uppercase; margin-bottom: 1rem; }
            .news-title { color: #003d6b; font-size: 1.4rem; font-weight: 700; line-height: 1.3; margin: 0 0 1rem 0; }
            .news-excerpt { color: #475569; font-size: 0.95rem; line-height: 1.6; margin-bottom: 1.5rem; flex-grow: 1; }
            .read-more { color: #0167c2; font-weight: 800; font-size: 0.85rem; }
            @media (max-width: 720px) { .news-hub-header h1 { font-size: 2rem; } .news-grid { grid-template-columns: 1fr; } }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <Breadcrumbs />
            <header class="news-hub-header">
                <h1>Notícias do Mercado</h1>
                <p>Fatos e indicadores oficiais republicados via Agência Brasil.</p>
            </header>

            {noticias.length > 0 ? (
                <ul class="news-grid">
                    {noticias.map((post) => (
                        <li class="news-card">
                            <a href={post.url}>
                                {post.frontmatter.heroImage && (
                                    <img class="news-image" src={post.frontmatter.heroImage} alt={post.frontmatter.title} />
                                )}
                                <div class="news-content">
                                    <div class="news-meta">
                                        <span>Economia</span>
                                        <span>•</span>
                                        <FormattedDate date={new Date(post.frontmatter.pubDate)} />
                                    </div>
                                    <h2 class="news-title">{post.frontmatter.title}</h2>
                                    <p class="news-excerpt">{post.frontmatter.description}</p>
                                    <span class="read-more">Ler notícia completa →</span>
                                </div>
                            </a>
                        </li>
                    ))}
                </ul>
            ) : (
                <div style="text-align: center; padding: 4rem; color: #64748b;">
                    <p>Nenhuma notícia encontrada na pasta de páginas.</p>
                </div>
            )}
        </main>
        <Footer />
    </body>
</html>