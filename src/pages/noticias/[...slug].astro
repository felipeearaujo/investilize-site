---
import { getCollection, render } from 'astro:content';
import NoticiaLayout from '../../layouts/NoticiaLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro'; // ✅ 1. Importar o componente

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias
    .filter(n => n.id !== 'index' && n.id !== 'index.md' && n.id !== 'index.mdx')
    .map((noticia) => {
      const cleanSlug = noticia.id.replace(/\.mdx?$/, '');
      return {
        params: { slug: cleanSlug },
        props: noticia,
      };
    });
}

const noticia = Astro.props;
const { Content } = await render(noticia);
---

<NoticiaLayout frontmatter={noticia.data}>
  {/* ✅ 2. Inserir o Breadcrumbs aqui para ele aparecer no topo da notícia */}
  <Breadcrumbs /> 
  <Content />
</NoticiaLayout>