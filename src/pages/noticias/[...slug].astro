---
import { getCollection } from 'astro:content';
import NoticiaLayout from '../../layouts/NoticiaLayout.astro';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias
    .filter(n => n.slug !== undefined && n.slug !== 'index') // ✅ Filtra o que poderia colidir
    .map((noticia) => ({
      params: { slug: noticia.id },
      props: noticia,
    }));
}

const noticia = Astro.props;
const { Content } = await noticia.render();
---

<NoticiaLayout {...noticia.data}>
  <Content />
</NoticiaLayout>