---
import { getCollection, render } from 'astro:content';
import NoticiaLayout from '../../layouts/NoticiaLayout.astro';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias
    .filter(n => n.id !== 'index' && n.id !== 'index.md' && n.id !== 'index.mdx') // ✅ Filtra o index base se houver
    .map((noticia) => {
      // Cria um slug limpo removendo a extensão do arquivo (.md ou .mdx)
      const cleanSlug = noticia.id.replace(/\.mdx?$/, '');
      return {
        params: { slug: cleanSlug },
        props: noticia,
      };
    });
}

const noticia = Astro.props;
const { Content } = await render(noticia);
---

<NoticiaLayout frontmatter={noticia.data}>
  <Content />
</NoticiaLayout>