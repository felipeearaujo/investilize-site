---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FormattedDate from '../../components/FormattedDate.astro';

const pageTitle = "Notícias Econômicas e Financeiras | Investilize";
const pageDescription = "Acompanhe as notícias que movimentam o mercado e a economia.";

const allPosts = await getCollection('noticias');
const noticias = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="pt-BR">
    <head>
        <meta charset="utf-8" />
        <BaseHead title={pageTitle} description={pageDescription} />
        <script is:inline>
            // Lógica de fallback para os cards da listagem (troca extensões se falhar)
            function handleCardError(img) {
                const fallback = "/images/noticias/default-investilize.webp";
                if (img.src.includes('.webp')) {
                    img.src = img.src.replace('.webp', '.jpg');
                } else if (img.src.includes('.jpg')) {
                    img.src = img.src.replace('.jpg', '.png');
                } else {
                    img.src = fallback;
                    img.onerror = null;
                }
            }
        </script>
        <style>
            main { width: 1100px; max-width: 95%; margin: 0 auto; padding: 2rem 0; }
            .news-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2.5rem; list-style: none; padding: 0; }
            .news-card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden; transition: all 0.3s ease; height: 100%; display: flex; flex-direction: column; }
            .news-card:hover { transform: translateY(-5px); box-shadow: 0 12px 24px rgba(0, 61, 107, 0.1); border-color: #0167c2; }
            .news-image-box { width: 100%; height: 200px; overflow: hidden; background: #f8fafc; }
            .news-image { width: 100%; height: 100%; object-fit: cover; }
            .news-content { padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column; }
            .news-title { font-size: 1.25rem; color: #003d6b; font-weight: 700; margin-bottom: 0.75rem; line-height: 1.3; }
            .card-link { text-decoration: none; color: inherit; height: 100%; display: flex; flex-direction: column; }
        </style>
    </head>
    <body>
        <Header />
        <main>
            <Breadcrumbs />
            <ul class="news-grid">
                {noticias.map((post) => {
                    const slug = post.id.replace(/\.mdx?$/, '');
                    
                    // SEGURANÇA: Extrai a URL da imagem se for objeto ou usa a string
                    let raw = post.data.heroImage || "";
                    let rawString = (typeof raw === 'object' && raw !== null) ? (raw.src || "") : String(raw);
                    
                    // Se o heroImage for o fallback padrão ou vazio, forçamos a busca pelo slug.webp
                    let displayPath = (rawString !== "" && !rawString.includes("default-investilize"))
                        ? rawString
                        : `/images/noticias/${slug}.webp`;

                    if (!displayPath.startsWith('/') && !displayPath.startsWith('http')) {
                        displayPath = `/images/noticias/${displayPath}`;
                    }

                    return (
                        <li class="news-card">
                            <a href={`/noticias/${slug}/`} class="card-link">
                                <div class="news-image-box">
                                    <img 
                                        class="news-image" 
                                        src={displayPath} 
                                        alt={post.data.title} 
                                        onerror="handleCardError(this)"
                                        loading="lazy"
                                    />
                                </div>
                                <div class="news-content">
                                    <div style="font-size: 0.8rem; color: #94a3b8; margin-bottom: 0.5rem; font-weight: 600;">
                                        ECONOMIA • <FormattedDate date={post.data.pubDate} />
                                    </div>
                                    <h2 class="news-title">{post.data.title}</h2>
                                    <p style="font-size: 0.95rem; color: #64748b; margin-bottom: 1.5rem;">{post.data.description}</p>
                                    <span style="color: #0167c2; font-weight: 700; font-size: 0.9rem; margin-top: auto;">Ler notícia →</span>
                                </div>
                            </a>
                        </li>
                    );
                })}
            </ul>
        </main>
        <Footer />
    </body>
</html>